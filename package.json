{
  "name": "locus",
  "private": true,
  "license": "GPL-3.0-or-later",
  "version": "0.5.2",
  "releaseChannel": "stable",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "typecheck:test": "vue-tsc --noEmit -p tsconfig.test.json",
    "release:generate": "cd docs && bun run release:generate",
    "release:verify-version": "bun run scripts/verify-release-version.mjs",
    "release": "bun run release:generate && bun run release:verify-version && bun run docs:validate",
    "build": "bun run typecheck && vite build",
    "build:tauri": "bun run build:tauri:with_embed_python_git",
    "build:tauri:with_embed_python_git": "bun run unity:bundle && bun run compile-server:bundle && bun run ort:bundle && bun run python:bundle && bun run git:bundle && bun run github-cli:bundle && bun run licenses:bundle && bun run view-runtime:export && bun run build",
    "build:tauri:without_embed_python_git": "bun run unity:bundle && bun run compile-server:bundle && bun run ort:bundle && bun run github-cli:bundle && bun run licenses:bundle && bun run view-runtime:export && bun run build",
    "release:installers": "bun run scripts/build-release-installers.mjs",
    "release:installers:lzma": "bun run scripts/build-release-installers.mjs --compression=lzma",
    "compile-server:bundle": "bun run scripts/build-locus-compile-server.mjs",
    "compile-server:ensure": "bun run scripts/ensure-locus-compile-server.mjs",
    "unity:bundle": "bun run unity:bundle-roslyn && bun run unity:bundle-json && bun run unity:bundle-detour && bun run unity:bundle-hotreload-runtime && bun run unity:bundle-native",
    "unity:bundle-roslyn": "bun run scripts/build-locus-roslyn-bundle.mjs",
    "unity:bundle-json": "bun run scripts/build-locus-json-bundle.mjs",
    "unity:bundle-detour": "bun run scripts/build-locus-detour-bundle.mjs",
    "unity:bundle-hotreload-runtime": "bun run scripts/build-locus-hotreload-runtime.mjs",
    "unity:bundle-native": "bun run scripts/build-locus-native-plugin.mjs",
    "python:bundle": "bun run scripts/prepare-managed-python.mjs",
    "git:bundle": "bun run scripts/prepare-managed-git.mjs",
    "github-cli:bundle": "bun run scripts/prepare-managed-github-cli.mjs",
    "ort:bundle": "bun run scripts/prepare-ort-runtime.mjs",
    "licenses:bundle": "bun run scripts/generate-third-party-bundle.mjs",
    "view-runtime:export": "bun run scripts/export-view-runtime-sources.mjs",
    "preview": "vite preview",
    "tauri": "bun run scripts/run-tauri.mjs",
    "locus:test:unity": "bun run scripts/locus-unity-test.mjs",
    "locus:test:unity:matrix": "bun run scripts/locus-unity-test-matrix.mjs --prepare-native --install-plugin",
    "locus:test:unity:matrix:smoke": "bun run scripts/locus-unity-test-matrix.mjs --prepare-native --install-plugin --suite connect,native-bridge,state-probe --connect-timeout-ms 60000 --timeout-ms 300000 --poll-ms 500 --no-progress-timeout-ms 60000",
    "locus:test:unity:native": "bun run scripts/locus-unity-test.mjs --prepare-native --install-plugin --suite connect,native-bridge --connect-timeout-ms 60000 --timeout-ms 300000 --poll-ms 500 --no-progress-timeout-ms 60000",
    "locus:test:unity:smoke": "bun run scripts/locus-unity-test.mjs --prepare-native --install-plugin --suite connect,native-bridge,state-probe --connect-timeout-ms 60000 --timeout-ms 300000 --poll-ms 500 --no-progress-timeout-ms 60000",
    "locus:test:unity:release": "bun run scripts/locus-unity-test.mjs --prepare-native --install-plugin --suite connect,hot-reload-release --connect-timeout-ms 60000 --timeout-ms 1200000 --poll-ms 500 --no-progress-timeout-ms 60000",
    "locus:test:unity:full": "bun run scripts/locus-unity-test.mjs --prepare-native --install-plugin --suite all --connect-timeout-ms 60000 --timeout-ms 1200000 --poll-ms 500 --no-progress-timeout-ms 60000",
    "docs:dev": "cd docs && bun run dev",
    "docs:validate": "cd docs && bun run validate",
    "docs:broken-links": "cd docs && bun run broken-links",
    "docs:build": "cd docs && bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@types/three": "^0.183.1",
    "@types/turndown": "^5.0.6",
    "@vue/compiler-sfc": "^3.5.13",
    "ag-psd": "^30.1.0",
    "dompurify": "^3.4.8",
    "elkjs": "^0.11.1",
    "highlight.js": "^11.11.1",
    "lucide": "^1.11.0",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3",
    "pinia": "^3.0.4",
    "three": "^0.183.2",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "vditor": "^3.11.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.1.10"
  }
}
